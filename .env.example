# ============================================================
# Prompt Compiler API — Environment Variables
# Copy this file to .env (never commit .env to source control)
# ============================================================

# --- Server --------------------------------------------------
PORT=8787
PROMPT_COMPILER_ENV=development
PROMPT_COMPILER_EXPORT_DIR=.prompt-compiler/exports

# --- Profile Library Store ----------------------------------
# Options: memory | sqlite
PROFILE_STORE_TYPE=sqlite
PROFILE_STORE_SQLITE=./data/profiles.db

# --- Usage Ledger Store -------------------------------------
# Options: memory | sqlite
USAGE_LEDGER_STORE_TYPE=sqlite
USAGE_LEDGER_SQLITE=./data/usage.db

# --- Billing Account Store ----------------------------------
# Options: memory | sqlite
BILLING_ACCOUNT_STORE_TYPE=sqlite
BILLING_ACCOUNT_STORE_SQLITE=./data/billing.db

# --- Feedback Store -----------------------------------------
# Options: memory | sqlite
FEEDBACK_STORE_TYPE=memory
FEEDBACK_STORE_SQLITE=./data/feedback.db

# --- Stripe Billing Integration -----------------------------
# Webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret_here

# Stripe API secret key (sk_test_* for test mode, sk_live_* for production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe publishable key (pk_test_* for test mode, pk_live_* for production)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here

# --- Auth ---------------------------------------------------
# Set to true to bypass Auth header checks in local development.
# MUST be false or unset in production.
AUTH_BYPASS=true

# --- CORS ---------------------------------------------------
# Comma-separated list of allowed origins for CORS (production only).
# ALLOWED_ORIGINS=https://your-domain.com

# --- Data directory -----------------------------------------
# Root directory for SQLite database files (relative to project root).
DATA_DIR=./data
