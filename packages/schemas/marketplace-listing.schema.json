{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-compiler.dev/schemas/marketplace-listing.schema.json",
  "title": "MarketplaceListingDocument",
  "description": "A shareable brand profile or template pack listed in the Prompt Compiler marketplace.",
  "type": "object",
  "required": [
    "listingId",
    "listingType",
    "status",
    "publishedBy",
    "displayName",
    "requiredEntitlement",
    "payload",
    "version",
    "publishedAt",
    "updatedAt",
    "installCount"
  ],
  "additionalProperties": false,
  "properties": {
    "listingId": {
      "type": "string",
      "description": "Unique listing ID (UUID)."
    },
    "listingType": {
      "type": "string",
      "enum": ["brand-profile", "template-pack"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "archived"]
    },
    "publishedBy": {
      "type": "string",
      "description": "Account ID of the creator who published this listing."
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredEntitlement": {
      "type": "string",
      "enum": ["pro.creator", "studio.team"],
      "description": "Entitlement required to publish. Browsing and installing are always free."
    },
    "payload": {
      "type": "object",
      "description": "The serialized brand profile or template pack payload."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "installCount": {
      "type": "integer",
      "minimum": 0
    }
  }
}
