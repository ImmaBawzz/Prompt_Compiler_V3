{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "brand-profile.schema.json",
  "title": "BrandProfile",
  "type": "object",
  "required": [
    "id",
    "brandName",
    "voice"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "brandName": {
      "type": "string"
    },
    "voice": {
      "type": "string"
    },
    "learningMode": {
      "type": "string",
      "enum": ["manual", "manual-review", "scheduled", "responsive", "autonomous"],
      "description": "How the profile learns from feedback: manual (no auto-update), manual-review (requires approval), scheduled (batch updates), responsive (reactive to feedback), autonomous (auto-promotes qualified versions)"
    },
    "signatureMotifs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preferredLanguage": {
      "type": "string"
    },
    "avoid": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "formatPreferences": {
      "type": "object"
    },
    "toneWeights": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
