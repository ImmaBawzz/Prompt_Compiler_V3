{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prompt-brief.schema.json",
  "title": "PromptBrief",
  "type": "object",
  "required": [
    "id",
    "title",
    "concept",
    "targets",
    "genres",
    "mood"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "concept": {
      "type": "string"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "genres": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "mood": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "energy": {
      "type": "number",
      "minimum": 1,
      "maximum": 10
    },
    "bpm": {
      "type": "number"
    },
    "key": {
      "type": "string"
    },
    "vocals": {
      "type": "string"
    },
    "imagery": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "structure": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
