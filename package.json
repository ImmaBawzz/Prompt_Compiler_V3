{
  "name": "prompt-compiler-v3-monorepo",
  "private": true,
  "version": "0.4.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "verify": "npm run validate:structure && npm run validate:imports && npm run validate:versions && npm run clean && npm run build && npm run test && npm run status",
    "clean": "node scripts/clean.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "validate:structure": "node scripts/validate-structure.mjs",
    "validate:imports": "node scripts/validate-import-boundaries.mjs",
    "validate:versions": "node scripts/check-version-sync.mjs",
    "status": "node scripts/render-task-status.mjs",
    "sample:cli": "npm --workspace packages/cli run sample",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:extension": "npm --workspace apps/extension run watch",
    "package:extension": "npm --workspace apps/extension run package",
    "release:evaluate": "node scripts/evaluate-milestone-release.mjs",
    "release:prepare": "node scripts/prepare-release.mjs --mode=pr",
    "release:prepare:direct": "node scripts/prepare-release.mjs --mode=direct",
    "ops:set-gh-secrets": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/set-github-secrets.ps1",
    "agent2:run": "node --experimental-strip-types scripts/agent2-runner.ts",
    "agent2:watchdog": "node --experimental-strip-types scripts/agent2-watchdog.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.8.3"
  }
}
