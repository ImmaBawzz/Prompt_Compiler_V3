{
  "name": "prompt-compiler-extension",
  "displayName": "Prompt Compiler",
  "description": "Compile, refine, and export AI prompt bundles for music, video, and multimodal creative workflows — directly from VS Code.",
  "publisher": "local-dev",
  "version": "0.4.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ImmaBawzz/Prompt_Compiler_V3"
  },
  "homepage": "https://github.com/ImmaBawzz/Prompt_Compiler_V3#readme",
  "bugs": {
    "url": "https://github.com/ImmaBawzz/Prompt_Compiler_V3/issues"
  },
  "keywords": [
    "prompt",
    "AI",
    "music",
    "video",
    "creative",
    "compiler",
    "suno",
    "udio",
    "flux",
    "kling"
  ],
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "preview": false,
  "activationEvents": [
    "onCommand:promptCompiler.openStudio",
    "onCommand:promptCompiler.exportSampleBrief",
    "onCommand:promptCompiler.startBundleReview",
    "onCommand:promptCompiler.showBundleReviewStatus",
    "onCommand:promptCompiler.addBundleReviewComment",
    "onCommand:promptCompiler.reviewBundleDecision",
    "onCommand:promptCompiler.syncPushProfileLibrary",
    "onCommand:promptCompiler.syncPullProfileLibrary",
    "onView:promptCompilerArtifacts"
  ],
  "main": "./dist/apps/extension/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptCompiler.openStudio",
        "title": "Prompt Compiler: Open Studio"
      },
      {
        "command": "promptCompiler.exportSampleBrief",
        "title": "Prompt Compiler: Export Sample Brief"
      },
      {
        "command": "promptCompiler.compileActiveJson",
        "title": "Prompt Compiler: Compile Active JSON Brief"
      },
      {
        "command": "promptCompiler.sendToProvider",
        "title": "Prompt Compiler: Send to Provider"
      },
      {
        "command": "promptCompiler.startBundleReview",
        "title": "Prompt Compiler: Start Bundle Review"
      },
      {
        "command": "promptCompiler.showBundleReviewStatus",
        "title": "Prompt Compiler: Show Bundle Review Status"
      },
      {
        "command": "promptCompiler.addBundleReviewComment",
        "title": "Prompt Compiler: Add Bundle Review Comment"
      },
      {
        "command": "promptCompiler.reviewBundleDecision",
        "title": "Prompt Compiler: Review Bundle Decision"
      },
      {
        "command": "promptCompiler.publishBundle",
        "title": "Prompt Compiler: Publish Bundle"
      },
      {
        "command": "promptCompiler.showFeedbackAggregate",
        "title": "Prompt Compiler: Show Feedback Aggregate"
      },
      {
        "command": "promptCompiler.showLearningTimeline",
        "title": "Prompt Compiler: Show Learning Timeline"
      },
      {
        "command": "promptCompiler.browseMarketplace",
        "title": "Prompt Compiler: Browse Marketplace"
      },
      {
        "command": "promptCompiler.refreshArtifacts",
        "title": "Prompt Compiler: Refresh Artifact Explorer"
      },
      {
        "command": "promptCompiler.revealLatestExportFolder",
        "title": "Prompt Compiler: Reveal Latest Export Folder"
      },
      {
        "command": "promptCompiler.syncPushProfileLibrary",
        "title": "Prompt Compiler: Sync Push Profile Library (Hosted)"
      },
      {
        "command": "promptCompiler.syncPullProfileLibrary",
        "title": "Prompt Compiler: Sync Pull Profile Library (Hosted)"
      }
    ],
    "configuration": {
      "title": "Prompt Compiler",
      "properties": {
        "promptCompiler.hostedApiBaseUrl": {
          "type": "string",
          "default": "http://localhost:8787",
          "description": "Base URL for hosted sync routes used by Prompt Compiler extension sync intent commands."
        },
        "promptCompiler.releaseChannel": {
          "type": "string",
          "enum": [
            "stable",
            "preview"
          ],
          "default": "stable",
          "enumDescriptions": [
            "Stable channel — production-ready features only.",
            "Preview channel — includes experimental and in-development features."
          ],
          "description": "Release channel for Prompt Compiler. Preview enables experimental features before they reach stable."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "promptCompilerArtifacts",
          "name": "Prompt Compiler Artifacts"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "promptCompiler.refreshArtifacts",
          "when": "view == promptCompilerArtifacts",
          "group": "navigation"
        },
        {
          "command": "promptCompiler.revealLatestExportFolder",
          "when": "view == promptCompilerArtifacts",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "promptCompiler.sendToProvider",
          "when": "view == promptCompilerArtifacts && viewItem == promptCompiler.artifact",
          "group": "inline"
        },
        {
          "command": "promptCompiler.publishBundle",
          "when": "view == promptCompilerArtifacts && viewItem == promptCompiler.artifact",
          "group": "inline@1"
        },
        {
          "command": "promptCompiler.showBundleReviewStatus",
          "when": "view == promptCompilerArtifacts && viewItem == promptCompiler.artifact",
          "group": "inline@2"
        },
        {
          "command": "promptCompiler.showFeedbackAggregate",
          "when": "view == promptCompilerArtifacts && viewItem == promptCompiler.artifact",
          "group": "inline@3"
        },
        {
          "command": "promptCompiler.showLearningTimeline",
          "when": "view == promptCompilerArtifacts && viewItem == promptCompiler.artifact",
          "group": "inline@4"
        },
        {
          "command": "promptCompiler.startBundleReview",
          "when": "view == promptCompilerArtifacts && viewItem == promptCompiler.artifact",
          "group": "navigation"
        },
        {
          "command": "promptCompiler.addBundleReviewComment",
          "when": "view == promptCompilerArtifacts && viewItem == promptCompiler.artifact",
          "group": "navigation@1"
        },
        {
          "command": "promptCompiler.reviewBundleDecision",
          "when": "view == promptCompilerArtifacts && viewItem == promptCompiler.artifact",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/apps/extension/src/__tests__/*.test.js",
    "package": "npx vsce package --no-dependencies"
  },
  "dependencies": {
    "@prompt-compiler/core": "0.4.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0"
  }
}
